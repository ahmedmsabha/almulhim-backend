generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  student
  admin
}

enum StudentRegion {
  gaza
  west_bank
}

enum ContentRegion {
  gaza
  west_bank
  both
}

enum SubscriptionStatus {
  pending_review
  pending_approval
  active
  expired
  rejected
  suspended
}

enum LessonAccessLevel {
  preview
  subscriber_only
}

enum SupportRequestStatus {
  open
  reviewed
  closed
}

enum DeviceType {
  web
  mobile
}

model User {
  id               String        @id @default(uuid()) @db.Uuid
  clerkId          String        @unique @map("clerk_id")
  email            String        @unique
  fullName         String        @map("full_name")
  phoneNumber      String        @map("phone_number")
  telegramUsername String        @map("telegram_username")
  region           StudentRegion
  role             UserRole      @default(student)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  subscriptions   Subscription[]
  supportRequests SupportRequest[]
  deviceBindings  DeviceBinding[]
  videoDownloads  VideoDownload[]

  @@map("users")
}

model SubscriptionPlan {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  priceAmount  Int      @map("price_amount")
  currency     String   @default("ILS")
  durationDays Int      @map("duration_days")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  userId             String             @map("user_id") @db.Uuid
  planId             String             @map("plan_id") @db.Uuid
  status             SubscriptionStatus
  receiptStorageKey  String?            @map("receipt_storage_key")
  receiptSenderName  String?            @map("receipt_sender_name")
  verificationResult Json?              @map("verification_result")
  verifiedAt         DateTime?          @map("verified_at")
  approvedAt         DateTime?          @map("approved_at")
  rejectedAt         DateTime?          @map("rejected_at")
  expiresAt          DateTime?          @map("expires_at")
  suspendedAt        DateTime?          @map("suspended_at")
  rejectionReason    String?            @map("rejection_reason")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId, status])
  @@index([status])
  @@map("subscriptions")
}

model Unit {
  id          String        @id @default(uuid()) @db.Uuid
  title       String
  description String?
  region      ContentRegion
  sortOrder   Int           @default(0) @map("sort_order")
  isPublished Boolean       @default(false) @map("is_published")
  publishedAt DateTime?     @map("published_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  chapters Chapter[]

  @@index([region, isPublished, sortOrder])
  @@map("units")
}

model Chapter {
  id          String    @id @default(uuid()) @db.Uuid
  unitId      String    @map("unit_id") @db.Uuid
  title       String
  sortOrder   Int       @default(0) @map("sort_order")
  isPublished Boolean   @default(false) @map("is_published")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  unit    Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([unitId, sortOrder])
  @@map("chapters")
}

model Lesson {
  id          String            @id @default(uuid()) @db.Uuid
  chapterId   String            @map("chapter_id") @db.Uuid
  title       String
  sortOrder   Int               @default(0) @map("sort_order")
  accessLevel LessonAccessLevel @default(subscriber_only) @map("access_level")
  isPublished Boolean           @default(false) @map("is_published")
  publishedAt DateTime?         @map("published_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  chapter Chapter       @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  videos  LessonVideo[]
  pdfs    LessonPdf[]

  @@index([chapterId, sortOrder])
  @@map("lessons")
}

model LessonVideo {
  id              String   @id @default(uuid()) @db.Uuid
  lessonId        String   @map("lesson_id") @db.Uuid
  storageKey      String   @map("storage_key")
  title           String?
  durationSeconds Int?     @map("duration_seconds")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  lesson    Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  downloads VideoDownload[]

  @@index([lessonId, sortOrder])
  @@map("lesson_videos")
}

model LessonPdf {
  id         String   @id @default(uuid()) @db.Uuid
  lessonId   String   @map("lesson_id") @db.Uuid
  storageKey String   @map("storage_key")
  title      String?
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, sortOrder])
  @@map("lesson_pdfs")
}

model Announcement {
  id              String        @id @default(uuid()) @db.Uuid
  title           String
  body            String
  imageStorageKey String?       @map("image_storage_key")
  region          ContentRegion
  isPublished     Boolean       @default(false) @map("is_published")
  publishedAt     DateTime?     @map("published_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([region, isPublished, publishedAt])
  @@map("announcements")
}

model SupportRequest {
  id         String               @id @default(uuid()) @db.Uuid
  userId     String               @map("user_id") @db.Uuid
  subject    String
  message    String
  status     SupportRequestStatus @default(open)
  adminReply String?              @map("admin_reply")
  reviewedAt DateTime?            @map("reviewed_at")
  closedAt   DateTime?            @map("closed_at")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("support_requests")
}

model DeviceBinding {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  deviceType DeviceType @map("device_type")
  deviceHash String     @map("device_hash")
  boundAt    DateTime   @default(now()) @map("bound_at")
  lastSeenAt DateTime?  @map("last_seen_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceType])
  @@map("device_bindings")
}

model VideoDownload {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  lessonVideoId String    @map("lesson_video_id") @db.Uuid
  deviceHash    String    @map("device_hash")
  downloadedAt  DateTime  @default(now()) @map("downloaded_at")
  revokedAt     DateTime? @map("revoked_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonVideo LessonVideo @relation(fields: [lessonVideoId], references: [id], onDelete: Cascade)

  @@index([userId, lessonVideoId])
  @@index([lessonVideoId, revokedAt])
  @@map("video_downloads")
}
